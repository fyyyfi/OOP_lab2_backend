# Copy to .env and adjust for your environment.
APP_NAME=ZHKG Service API
# SQLite (default, zero-config):
DATABASE_URL=sqlite:///./zhkg.db
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/zhkg
JWT_SECRET=please-change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
